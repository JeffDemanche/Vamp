{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "noEmit": true,
    "declaration": false,
    "sourceMap": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "types": ["node", "vite/client", "jest", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@vamp/shared": ["../shared/src/index.ts"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "codegen.ts",
    "playwright.config.ts",
    "e2e"
  ],
  "exclude": ["node_modules", "dist", "test-results", "playwright-report"]
}
