# Dependencies (reinstalled inside the image so Linux-native binaries are used)
**/node_modules

# Build output
**/dist
**/build
**/*.tsbuildinfo

# Local env files (values are provided via docker-compose instead)
**/.env
**/.env.local
**/.env.*.local

# Generated GraphQL artifacts (regenerated inside the container)
app/src/generated

# Tests / coverage / Playwright
**/coverage
app/test-results
app/playwright-report
app/playwright/.cache

# Caches
**/.cache
**/.vite

# VCS & editor / OS
.git
.gitignore
.idea
.vscode
**/.DS_Store
**/*.log

# Docker artifacts themselves
Dockerfile
.dockerignore
docker-compose.yml
