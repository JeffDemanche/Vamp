{
  "name": "vamp",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Vamp, a collaborative music-making app",
  "workspaces": [
    "server",
    "app"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:server": "npm run dev --workspace server",
    "dev:app": "npm run dev --workspace app",
    "codegen": "npm run codegen --workspace app",
    "schema": "npm run schema --workspace server",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:watch": "docker compose watch"
  },
  "engines": {
    "node": ">=20"
  }
}
