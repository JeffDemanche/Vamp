{
  "name": "@vamp/server",
  "version": "0.1.0",
  "private": true,
  "description": "Vamp GraphQL API server (Express + Apollo + type-graphql + Typegoose)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r reflect-metadata src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node -r reflect-metadata dist/index.js",
    "schema": "ts-node --transpile-only -r reflect-metadata src/emit-schema.ts",
    "test": "jest --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@typegoose/typegoose": "^13.3.0",
    "@vercel/blob": "^2.5.0",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "graphql-scalars": "^1.25.0",
    "mongoose": "~9.6.0",
    "reflect-metadata": "^0.2.2",
    "rita": "^3.2.16",
    "type-graphql": "2.0.0-rc.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
