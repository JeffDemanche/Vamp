# Server configuration
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/vamp
# `production` makes the session cookie Secure (HTTPS-only) and, by default,
# makes this server also serve the built React SPA (see SERVE_CLIENT below).
NODE_ENV=development

# Serving the built client (app/dist) from this server. Defaults to on in
# production, off in development (where Vite serves the client). Set to `false`
# to force-disable, or any other value to force-enable.
# SERVE_CLIENT=true
# Override the auto-detected client build directory if needed.
# CLIENT_DIST_DIR=/var/task/app/dist

# Authentication / sessions
SESSION_COOKIE_NAME=vamp_session
SESSION_TTL_DAYS=30

# Audio storage. The driver selects where clip audio bytes are stored:
#   local  — write files to AUDIO_LOCAL_DIR (default; no external service)
#   vercel — Vercel Blob (set BLOB_READ_WRITE_TOKEN)
AUDIO_STORAGE_DRIVER=local
# Base URL of this server, used to build client upload/download URLs. On Vercel
# this defaults to https://$VERCEL_URL when unset.
PUBLIC_BASE_URL=http://localhost:4000
# Directory the `local` driver writes audio to (relative to the server cwd).
AUDIO_LOCAL_DIR=.audio-uploads
# Required when AUDIO_STORAGE_DRIVER=vercel (read-write Blob token).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
