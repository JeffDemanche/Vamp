# Server configuration
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/vamp
# `production` makes the session cookie Secure (HTTPS-only).
NODE_ENV=development

# Authentication / sessions
SESSION_COOKIE_NAME=vamp_session
SESSION_TTL_DAYS=30

# S3 (uploads). In local dev these point at LocalStack; leave AWS_ENDPOINT_URL
# unset in production to use real AWS S3 with your real credentials.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=vamp-uploads
